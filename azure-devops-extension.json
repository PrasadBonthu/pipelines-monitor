{
  "manifestVersion": 1,
  "id": "pipelines-monitor-fix",
  "publisher": "prasadbonthu",
  "version": "0.3.11",
  "name": "Pipelines Monitor PB",
  "description": "A Azure DevOps extension designed to deliver insightful analytics on pipeline executions across your organization.",
  "public": false,
  "categories": ["Azure Pipelines"],
  "tags": ["Pipelines", "Dashboards", "Widgets", "Monitor"],
  "targets": [
    {
      "id": "Microsoft.VisualStudio.Services"
    }
  ],
  "icons": {
    "default": "static/logo.png"
  },
  "content": {
    "details": {
      "path": "README.md"
    },
    "license": {
      "path": "LICENSE"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/PrasadBonthu/pipelines-monitor"
  },
  "files": [
    {
      "path": "static",
      "addressable": true
    },
    {
      "path": "dist",
      "addressable": true
    }
  ]
}
